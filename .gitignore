# API private keys (never commit — leaking one means rotating it).
private-keys/
*.pk

# Local env files. Vite reads `.env` AND `.env.local` (and *.local was
# already ignored above); we exclude `.env` itself because devs drop
# secrets into it. Commit defaults via .env.example if needed in the future.
.env
.env.development
.env.production
