{
  "name": "simple-work-tracker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "cap:build": "CAPACITOR_BUILD=1 vite build && cap sync",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "cap:run:ios": "bun run cap:build && cap open ios",
    "cap:run:android": "bun run cap:build && cap open android",
    "electron:install": "cd electron && npm install --no-audit --no-fund",
    "electron:sync": "bun run cap:build && cap sync @capacitor-community/electron",
    "electron:start": "bun run electron:sync && cd electron && npm run electron:start",
    "electron:pack": "bun run electron:sync && cd electron && npm run electron:pack",
    "electron:dist": "bun run electron:sync && cd electron && npm run electron:make",
    "electron:release": "node scripts/electron-release.mjs",
    "gen:app-assets": "node scripts/generate-app-assets.mjs && bunx @capacitor/assets generate --ios --android --iconBackgroundColor '#0d9488' --iconBackgroundColorDark '#0d9488' --splashBackgroundColor '#ffffff' --splashBackgroundColorDark '#0f172a'"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.4.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/share": "^8.0.1",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@dnd-kit/core": "^6.3.1",
    "@livekit/components-react": "^2.9.9",
    "@livekit/components-styles": "^1.1.6",
    "@livekit/krisp-noise-filter": "^0.3.4",
    "@livekit/track-processors": "^0.7.2",
    "@mediapipe/tasks-vision": "0.10.14",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@supabase/supabase-js": "^2.101.0",
    "@uiw/react-codemirror": "^4.25.10",
    "@xyflow/react": "^12.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "emoji-picker-react": "^4.19.1",
    "exceljs": "^4.4.0",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "livekit-client": "^2.9.9",
    "lucide-react": "^0.473.0",
    "motion": "^12.23.24",
    "onnxruntime-web": "^1.27.0",
    "posthog-js": "^1.205.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^15.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@capacitor-community/electron": "^5.0.1",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.0",
    "@tailwindcss/vite": "^4.1.12",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.1.12",
    "vite": "^6.1.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.9"
  }
}
