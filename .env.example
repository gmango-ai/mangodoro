# Copy this to `.env` and fill in. Vite reads .env and .env.local;
# .env is gitignored (drops secrets), .env.example is committed.

# ── Supabase ───────────────────────────────────────────────────
# From Supabase Dashboard → Project Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── LiveKit (video) ────────────────────────────────────────────
# The only video provider. From LiveKit Cloud → your project → Settings.
# Only the URL is a client (VITE_) var.
VITE_LIVE_KIT_URL=        # wss://<project>.livekit.cloud
VITE_LIVE_KIT_ID=         # API key ("ID"). NOTE: the server signs tokens —
                          # set it server-side as LIVEKIT_API_KEY (below).
VITE_LIVE_KIT_SIP=        # SIP URI — telephony only, not used by the web app
#
# Server secrets for the `mint-livekit-token` edge function — set via:
#   supabase secrets set LIVEKIT_API_KEY=... LIVEKIT_API_SECRET=...
# The API SECRET must NEVER be a VITE_ var (those ship to the browser).

# ── PostHog (product metrics) ──────────────────────────────────
# Project API key from PostHog → Settings. Blank = analytics disabled.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=        # default https://us.i.posthog.com

# Web-push application server (VAPID) public key — safe to expose.
VITE_VAPID_PUBLIC_KEY=BKGflXYhNzfKfC2KyguD0pzWjVxiGDUDRhDa2d5aqcsgeKJ1zW1VVZhIKYe1PmdnOVp2URRnbPdb3FrYnLPo19U
