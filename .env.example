# Copy this to `.env` and fill in. Vite reads .env and .env.local;
# .env is gitignored (drops secrets), .env.example is committed.

# ── Supabase ───────────────────────────────────────────────────
# From Supabase Dashboard → Project Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Jitsi / JaaS ───────────────────────────────────────────────
# AppID = your JaaS tenant identifier (vpaas-magic-cookie-…).
# Leave blank to fall back to public meet.jit.si.
VITE_JITSI_APP_ID=

# OPTIONAL: a static JWT used as a local-dev backstop when the
# `mint-jaas-jwt` Supabase edge function isn't deployed or reachable
# (e.g. running offline). Mint one via:
#   bun run scripts/jaas-mint.mjs
# Production deploys do NOT need this — the edge function mints
# per-user tokens against the Supabase secret JAAS_PRIVATE_KEY.
VITE_JITSI_DEV_JWT=

# ── Local-only (NOT needed on Vercel) ──────────────────────────
# Used by scripts/jaas-mint.mjs to sign dev JWTs.
VITE_JAAS_KID=
# JAAS_PRIVATE_KEY_PATH=./private-keys/jaas.pk  (default)

# ── LiveKit (video A/B test vs Jitsi) ──────────────────────────
# From LiveKit Cloud → your project → Settings.
# Only the URL is a client (VITE_) var. Leave blank to keep every
# room on Jitsi (the A/B only routes to LiveKit once this is set).
VITE_LIVE_KIT_URL=        # wss://<project>.livekit.cloud
VITE_LIVE_KIT_ID=         # API key ("ID"). NOTE: the server signs tokens —
                          # set it server-side as LIVEKIT_API_KEY (below).
VITE_LIVE_KIT_SIP=        # SIP URI — telephony only, not used by the web app
#
# Server secrets for the `mint-livekit-token` edge function — set via:
#   supabase secrets set LIVEKIT_API_KEY=... LIVEKIT_API_SECRET=...
# The API SECRET must NEVER be a VITE_ var (those ship to the browser).

# OPTIONAL: force a provider for manual testing (e.g. LiveKit on mobile),
# overriding the per-room A/B. Also available per-tab via ?video=livekit
# / ?video=jitsi in the URL.
VITE_VIDEO_FORCE=         # "livekit" | "jitsi" | (blank = A/B)

# ── PostHog (A/B metrics) ──────────────────────────────────────
# Project API key from PostHog → Settings. Blank = analytics disabled.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=        # default https://us.i.posthog.com
