# Copy this to `.env` and fill in. Vite reads .env and .env.local;
# .env is gitignored (drops secrets), .env.example is committed.

# ── Supabase ───────────────────────────────────────────────────
# From Supabase Dashboard → Project Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Jitsi / JaaS ───────────────────────────────────────────────
# AppID = your JaaS tenant identifier (vpaas-magic-cookie-…).
# Leave blank to fall back to public meet.jit.si.
VITE_JITSI_APP_ID=

# OPTIONAL: a static JWT used as a local-dev backstop when the
# `mint-jaas-jwt` Supabase edge function isn't deployed or reachable
# (e.g. running offline). Mint one via:
#   bun run scripts/jaas-mint.mjs
# Production deploys do NOT need this — the edge function mints
# per-user tokens against the Supabase secret JAAS_PRIVATE_KEY.
VITE_JITSI_DEV_JWT=

# ── Local-only (NOT needed on Vercel) ──────────────────────────
# Used by scripts/jaas-mint.mjs to sign dev JWTs.
VITE_JAAS_KID=
# JAAS_PRIVATE_KEY_PATH=./private-keys/jaas.pk  (default)
